TARGET_DIR = ./rust/target
LIBDIR = $(TARGET_DIR)/release
STATLIB = $(LIBDIR)/libvldaft.a
PKG_LIBS = -L$(LIBDIR) -lvldaft -lresolv

# C sources (existing)
C_SOURCES = init.c vldaft_fit.c loscreg8.c nrmod.c matrix.c apolyth.c dataio8.c loscpar.c entrypoint.c
OBJECTS = $(C_SOURCES:.c=.o)

all: $(SHLIB)

$(SHLIB): $(OBJECTS) $(STATLIB)

CARGOTMP = $(CURDIR)/.cargo

$(STATLIB):
	# In some environments, ~/.cargo/bin might not be in PATH, so we need
	# to set it here.
	if [ "$(NOT_CRAN)" != "true" ]; then \
		export CARGO_HOME=$(CARGOTMP); \
	fi && \
		export PATH="$(HOME)/.cargo/bin:$$PATH" && \
		cargo build --lib --release --manifest-path=./rust/Cargo.toml --target-dir $(TARGET_DIR)

clean:
	rm -Rf $(OBJECTS) $(STATLIB) $(TARGET_DIR)
