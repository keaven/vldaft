TARGET_DIR = ./rust/target
LIBDIR     = $(TARGET_DIR)/release
STATLIB    = $(LIBDIR)/libvldaft.a
PKG_LIBS   = -L$(LIBDIR) -lvldaft

# C sources compiled into the shared library.
C_SOURCES = init.c vldaft_fit.c vldaft_cure_eval.c dataio8.c loscreg8.c nrmod.c matrix.c
OBJECTS   = $(C_SOURCES:.c=.o)

all: $(SHLIB)

$(SHLIB): $(OBJECTS) $(STATLIB)

CARGOTMP = $(CURDIR)/.cargo

$(STATLIB):
	# Ensure ~/.cargo/bin is on PATH (it may not be on CRAN builders).
	if [ "$(NOT_CRAN)" != "true" ]; then \
		export CARGO_HOME=$(CARGOTMP); \
	fi && \
		export PATH="$(HOME)/.cargo/bin:$$PATH" && \
		cargo build --lib --release \
			--manifest-path=./rust/Cargo.toml \
			--target-dir $(TARGET_DIR)

clean:
	rm -Rf $(OBJECTS) $(SHLIB) $(STATLIB) $(TARGET_DIR) $(CARGOTMP)
